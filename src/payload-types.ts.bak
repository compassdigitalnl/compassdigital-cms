   */
  rating: number;
  /**
   * Toon op homepage
   */
  featured?: boolean | null;
  status?: ('published' | 'draft') | null;
  updatedAt: string;
  createdAt: string;
}
/**
 * Leveranciers, fabrikanten en partners
 *
