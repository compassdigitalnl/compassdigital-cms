     */
    lockMessage?: string | null;
  };
  /**
   * Producten genoemd in artikel (getoond in sidebar + inline embeds)
   */
  relatedProducts?: (number | Product)[] | null;
  /**
   * Handmatig geselecteerde gerelateerde artikelen (max 3)
   */
